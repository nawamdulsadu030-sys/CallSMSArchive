<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1A237E"
        android:gravity="center_vertical"
        android:paddingStart="16dp">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📁 Call &amp; SMS Archive"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="#FFFFFF">
        <Button
            android:id="@+id/btnCalls"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="📞 CALL LOG"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1565C0"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true"/>
        <Button
            android:id="@+id/btnSms"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="✉️ SMS LOG"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2E7D32"
            android:layout_marginStart="6dp"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/todayBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FF6F00"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📅 Today"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="13sp"/>
        <TextView
            android:id="@+id/tvTodayCalls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📞 0 Calls"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:background="#33FFFFFF"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:layout_marginEnd="6dp"/>
        <TextView
            android:id="@+id/tvTodaySms"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✉️ 0 SMS"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:background="#33FFFFFF"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📞 Call Records"
        android:textColor="#1A237E"
        android:textSize="13sp"
        android:textStyle="bold"
        android:padding="10dp"
        android:background="#E8EAF6"/>

    <TextView
        android:id="@+id/tvCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#757575"
        android:textSize="11sp"
        android:paddingStart="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:background="#FFFFFF"/>

    <ListView
        android:id="@+id/listView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:divider="#F0F0F0"
        android:dividerHeight="1dp"/>

</LinearLayout>
